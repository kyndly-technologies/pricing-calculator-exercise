{
  "name": "pricing-calculator-exercise-rails",
  "image": "mcr.microsoft.com/devcontainers/ruby:1-3.3-bookworm",
  "postCreateCommand": "bundle install && bin/rails db:prepare",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Rails App",
      "onAutoForward": "openPreview"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Shopify.ruby-lsp"
      ]
    }
  }
}
